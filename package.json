{
  "name": "@lucasygu/yc-cli",
  "version": "0.1.0",
  "description": "CLI tool for Y Combinator Startup School — submit weekly updates, track progress, manage your YC journey from the terminal",
  "type": "module",
  "main": "./dist/lib/client.js",
  "exports": {
    ".": "./dist/lib/client.js",
    "./cookies": "./dist/lib/cookies.js"
  },
  "bin": {
    "yc": "dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "SKILL.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ycombinator",
    "yc",
    "startup-school",
    "cli",
    "claude-code",
    "claude-code-skill"
  ],
  "author": "lucasygu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasygu/yc-cli.git"
  },
  "bugs": {
    "url": "https://github.com/lucasygu/yc-cli/issues"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.1.0",
    "commander": "^13.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
